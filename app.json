{
  "expo": {
    "name": "Todo Weather",
    "displayName": "Todo Weather",
    "slug": "global-todo-weather",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon-v3.png",
      "resizeMode": "contain",
      "backgroundColor": "#b2ebf2"
    },
    "locales": {
      "ko": "./src/i18n/locales/ko.json",
      "en": "./src/i18n/locales/en.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appswayd.TodoWeatherGlobal",
      "buildNumber": "23",
      "infoPlist": {
        "CFBundleLocalizations": [
          "ko",
          "en"
        ],
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "사용자의 현재 위치를 기반으로 정확한 날씨 정보를 제공하기 위해 위치 권한이 필요합니다.",
        "NSUserTrackingUsageDescription": "사용자의 관심사에 맞는 맞춤형 광고를 제공하기 위해 권한이 필요합니다."
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "backgroundColor": "#b2ebf2",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#469dd3"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.appswayd.TodoWeatherGlobal",
      "versionCode": 3,
      "googleServicesFile": "./google-services.json",
      "notification": {
        "color": "#b2ebf2"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
