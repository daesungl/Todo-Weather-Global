rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Invite codes — any authenticated user can read; only owner can create/modify/delete
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /flows/{flowId} {
        // Owner: full access
        // Members: read if membership doc exists; write (update) only if role == 'editor'
        allow read: if request.auth != null
          && (request.auth.uid == userId
              || exists(/databases/$(database)/documents/users/$(userId)/flows/$(flowId)/members/$(request.auth.uid)));
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null
          && (request.auth.uid == userId
              || (exists(/databases/$(database)/documents/users/$(userId)/flows/$(flowId)/members/$(request.auth.uid))
                  && get(/databases/$(database)/documents/users/$(userId)/flows/$(flowId)/members/$(request.auth.uid)).data.role == 'editor'));
        allow delete: if request.auth != null && request.auth.uid == userId;

        // Members sub-collection:
        // - Owner or the member themselves can read
        // - Anyone authenticated can create their OWN membership (self-join via invite code)
        // - Owner can delete any member; member can delete themselves (leave)
        match /members/{memberUid} {
          allow read: if request.auth != null
            && (request.auth.uid == userId || request.auth.uid == memberUid);
          allow create: if request.auth != null && request.auth.uid == memberUid;
          allow delete: if request.auth != null
            && (request.auth.uid == userId || request.auth.uid == memberUid);
        }

        match /comments/{commentId} {
          // Anyone who can read the flow can read comments
          allow read: if request.auth != null
            && (request.auth.uid == userId
                || exists(/databases/$(database)/documents/users/$(userId)/flows/$(flowId)/members/$(request.auth.uid)));
          
          // Any member can create a comment
          allow create: if request.auth != null
            && (request.auth.uid == userId
                || exists(/databases/$(database)/documents/users/$(userId)/flows/$(flowId)/members/$(request.auth.uid)));
          
          // Owner, Editor, or Author can delete
          allow delete: if request.auth != null
            && (request.auth.uid == userId
                || request.auth.uid == resource.data.uid
                || (exists(/databases/$(database)/documents/users/$(userId)/flows/$(flowId)/members/$(request.auth.uid))
                    && get(/databases/$(database)/documents/users/$(userId)/flows/$(flowId)/members/$(request.auth.uid)).data.role == 'editor'));
          
          allow update: if false; // Comments are immutable for simplicity
        }
      }

      match /regions/{regionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Pointers to flows shared with this user
      match /sharedFlows/{flowId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
