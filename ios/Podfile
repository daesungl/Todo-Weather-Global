require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

# Firebase Firestore 바이너리 SDK 사용 (빌드 속도 향상)
$FirebaseFirestoreBinary = true
# use_frameworks! 없이 RNFB 포드만 정적 프레임워크로 설정 (모듈 충돌 방지)
$RNFirebaseAsStaticFramework = true

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']
  
  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['RCT_NEW_ARCH_ENABLED'] ||= '0' if podfile_properties['newArchEnabled'] == 'false'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'TodoWeather' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  # GoogleSignIn 9.x 는 GTMSessionFetcher ~> 3.3 을, Firebase 12.x 는 >= 3.4, < 6.0 을 요구함.
  # 3.5.0 은 두 제약을 모두 만족하는 최신 3.x 버전으로 고정.
  pod 'GTMSessionFetcher', '~> 3.5'

  # Firebase Swift 포드들이 필요로 하는 ObjC 의존 포드에만 modular headers 활성화
  # (use_modular_headers! 전역 설정 대신 사용 — FirebaseAuth-Swift.h 빌드 타이밍 에러 방지)
  pod 'GoogleUtilities', :modular_headers => true
  pod 'FirebaseAuthInterop', :modular_headers => true
  pod 'FirebaseAppCheckInterop', :modular_headers => true
  pod 'RecaptchaInterop', :modular_headers => true
  pod 'FirebaseFirestoreInternal', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    # gRPC-C++ 가 기대하는 경로에 gRPC-Core.modulemap 심볼릭 링크 생성
    pods_root = installer.sandbox.root.to_s
    grpc_private_dir = "#{pods_root}/Headers/Private/grpc"
    grpc_modulemap_src = "#{pods_root}/Target Support Files/gRPC-Core/gRPC-Core.modulemap"
    if File.exist?(grpc_modulemap_src)
      system("mkdir -p '#{grpc_private_dir}'")
      system("ln -sf '#{grpc_modulemap_src}' '#{grpc_private_dir}/gRPC-Core.modulemap'")
    end

    # Firebase 12+ 에서 FIRAuth 는 Swift 로 작성됨.
    # ObjC 인터페이스(FirebaseAuth-Swift.h)는 빌드 시 "Swift Compatibility Header" 서브디렉토리에 생성되지만
    # Firebase.h 는 <FirebaseAuth/FirebaseAuth-Swift.h> (서브디렉토리 없음)로 임포트함.
    # 해결책: FirebaseAuth 컴파일 완료 후 심볼릭 링크를 생성하는 빌드 페이즈를 추가.
    installer.pods_project.targets.each do |target|
      if target.name == 'FirebaseAuth'
        phase = target.new_shell_script_build_phase('Link FirebaseAuth-Swift.h to expected location')
        phase.shell_script = <<-SHELL
COMPAT_DIR="${PODS_CONFIGURATION_BUILD_DIR}/FirebaseAuth/Swift Compatibility Header"
DEST="${PODS_CONFIGURATION_BUILD_DIR}/FirebaseAuth/FirebaseAuth-Swift.h"
if [ -f "${COMPAT_DIR}/FirebaseAuth-Swift.h" ] && [ ! -L "${DEST}" ]; then
  ln -sf "${COMPAT_DIR}/FirebaseAuth-Swift.h" "${DEST}"
fi
        SHELL
      end
    end

    # RNFB ObjC 포드들의 HEADER_SEARCH_PATHS 에 빌드 산출물 디렉토리 추가
    # (위 스크립트가 생성한 심볼릭 링크를 <FirebaseAuth/FirebaseAuth-Swift.h> 로 찾을 수 있게 함)
    rnfb_targets = ['RNFBApp', 'RNFBAuth', 'RNFBAnalytics', 'RNFBFirestore', 'RNFBStorage']
    installer.pods_project.targets.each do |target|
      if rnfb_targets.include?(target.name)
        target.build_configurations.each do |config|
          if target.name == 'RNFBApp'
            config.build_settings['DEFINES_MODULE'] = 'NO'
          end
          
          existing = config.build_settings['HEADER_SEARCH_PATHS'] || ['$(inherited)']
          if existing.is_a?(Array)
            config.build_settings['HEADER_SEARCH_PATHS'] = existing + ['"$(PODS_CONFIGURATION_BUILD_DIR)"']
          else
            config.build_settings['HEADER_SEARCH_PATHS'] = existing + ' "$(PODS_CONFIGURATION_BUILD_DIR)"'
          end
        end
      end
    end

    # FirebaseFirestore.podspec 이 weak_frameworks 로 FirebaseFirestoreInternal 을 선언하지만,
    # use_frameworks! 없이는 해당 포드가 정적 라이브러리로 빌드되므로 -weak_framework 플래그가 링커 오류를 유발함.
    # 생성된 xcconfig 에서 해당 플래그를 제거하여 수정.
    Dir.glob("#{installer.sandbox.root}/Target Support Files/Pods-TodoWeather/Pods-TodoWeather.*.xcconfig") do |xcconfig_path|
      content = File.read(xcconfig_path)
      modified = content.gsub('-weak_framework "FirebaseFirestoreInternal"', '')
      File.write(xcconfig_path, modified) if content != modified
    end
  end
end
